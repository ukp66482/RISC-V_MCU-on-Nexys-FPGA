###############################################################################
# Vivado (Tcl-based project flow)
# Only source files + Tcl scripts are version controlled
###############################################################################

# Vivado project artifacts (DO NOT version control)
*.xpr
*.jou
*.log
*.str
*.tmp
*.dcp

# Vivado working directories
.vivado/
*.cache/
*.runs/
*.hw/
*.ip_user_files/
*.sim/
*.sdk/

# IP cache & generated output
*.gen/
*.srcs/
*.ipcache/
*.xcix
*.xci.lock

# Bitstreams & reports (regenerable)
#*.bit
*.bin
*.ltx
*.rpt
*.pb

# Simulation outputs
xsim.dir/
*.wdb
*.vcd
*.fst

# Checkpoints
*.dcp
*.hwdef

###############################################################################
# OS / Editor
###############################################################################
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

###############################################################################
# Keep these (do NOT ignore)
# - *.tcl
# - rtl/*.v *.sv *.vhdl
# - constraints/*.xdc
# - README.md
###############################################################################


############################################
# Vitis / Eclipse workspace
############################################
.metadata/
.recommenders/
.settings/
*.log
workspace.log

############################################
# Xilinx build artifacts
############################################
.Xil/
Debug/
Release/
build/
bin/
out/

############################################
# Vitis / SDK generated files
############################################
*.elf
*.map
*.lst
*.o
*.a
*.d
*.cmake
*.xpfm
#*.xsa
*.xclbin
#*.bit
*.bin

############################################
# BSP / Platform auto-generated
############################################
**/bsp/ps7_cortexa9_0/
**/bsp/psu_cortexa53_0/
**/bsp/psu_cortexr5_0/
**/bsp/*.mss
**/bsp/*.json

############################################
# Temporary / cache
############################################
tmp/
.cache/
.cache_*
*.tmp
*.bak
*.swp

############################################
# OS / Editor
############################################
.DS_Store
Thumbs.db
.vscode/
.idea/
*.css

############################################
# Python / scripts cache (if any)
############################################
__pycache__/
*.pyc

/RISC-V-MCU

############################################
# Workspace example – ignore all except .c/.h sources
############################################
workspace-example/*
!workspace-example/GPIO_test/
workspace-example/GPIO_test/*
!workspace-example/GPIO_test/src/
workspace-example/GPIO_test/src/*
!workspace-example/GPIO_test/src/*.c
!workspace-example/GPIO_test/src/*.h
!workspace-example/PWM_test/
workspace-example/PWM_test/*
!workspace-example/PWM_test/src/
workspace-example/PWM_test/src/*
!workspace-example/PWM_test/src/*.c
!workspace-example/PWM_test/src/*.h
